# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias (publishable key format)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# App — production: https://rizzmyresume.sarwagyna.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay (Dashboard → Settings → API Keys)
# Dev: rzp_test_xxx | Production: rzp_live_xxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# ─── Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets) ───
# ANTHROPIC_API_KEY=
# LATEXLITE_API_KEY=
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
# RESEND_API_KEY=
# ALLOWED_ORIGIN=https://rizzmyresume.sarwagyna.com
# APP_URL=https://rizzmyresume.sarwagyna.com
# CRON_SECRET=random_long_secret_for_cleanup_job

# Payment is verified client-side after Razorpay checkout (no webhook required).
# Optional backup cleanup: schedule cleanup-resumes hourly with Authorization: Bearer <CRON_SECRET>
