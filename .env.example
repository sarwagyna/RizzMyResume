# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Razorpay (Dashboard → Settings → API Keys — use Test keys for dev)
# Public key: safe in the browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

# Server-only (Supabase Edge Functions → Project Settings → Edge Function Secrets)
# ANTHROPIC_API_KEY=
# LATEXLITE_API_KEY=
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_ANON_KEY=
# RESEND_API_KEY=
# CRON_SECRET=random_long_secret_for_cleanup_job

# Schedule cleanup-resumes hourly in Supabase Dashboard (Cron: 0 * * * *)
# POST /functions/v1/cleanup-resumes with header: Authorization: Bearer <CRON_SECRET>
